#!/usr/bin/env python3
import json as _json
import sys
from time import time
from uuid import uuid4

from engine.session import ChatGPT

try:
    import tiktoken
    _enc = tiktoken.get_encoding('o200k_base')
    def _count(s):
        return len(_enc.encode(s)) if s else 0
except ImportError:
    def _count(s):
        return max(1, len(s) // 4)


def _build_openai_response(result, prompt_text):
    model = result.get('model') or 'auto'
    text = result.get('text', '')
    now = int(time())
    msg_id = f'chatcmpl-{uuid4().hex[:16]}'

    reasoning = result.get('reasoning', '')
    citations = result.get('citations')
    content_refs = result.get('content_references')

    pt = _count(prompt_text)
    ct = _count(text)
    rt = _count(reasoning) if reasoning else 0

    choice_msg = {'role': 'assistant', 'content': text}
    if rt:
        choice_msg['reasoning_content'] = reasoning
    if citations:
        choice_msg['citations'] = citations
    if content_refs:
        choice_msg['content_references'] = content_refs

    usage = {'prompt_tokens': pt, 'completion_tokens': ct, 'total_tokens': pt + ct}
    if rt:
        usage['completion_tokens_details'] = {'reasoning_tokens': rt}

    body = {
        'id': msg_id,
        'object': 'chat.completion',
        'created': now,
        'model': model,
        'choices': [{'index': 0, 'message': choice_msg, 'finish_reason': 'stop'}],
        'usage': usage,
    }

    if result.get('conversation_id'):
        body['conversation_id'] = result['conversation_id']
    if result.get('parent_message_id'):
        body['parent_message_id'] = result['parent_message_id']
    if result.get('rate_limits'):
        body['rate_limits'] = result['rate_limits']
    if result.get('resume_token'):
        body['resume_token'] = result['resume_token']
    if result.get('plan_type'):
        body['plan_type'] = result['plan_type']
    if result.get('cluster_region'):
        body['cluster_region'] = result['cluster_region']
    if result.get('did_reasoning'):
        body['did_reasoning'] = True

    return body


def main():
    import argparse as _argparse
    parser = _argparse.ArgumentParser(description='anonchat — ChatGPT guest mode CLI')
    parser.add_argument('message', nargs='*', help='Message to send')
    parser.add_argument('--proxy', help='Proxy (http://user:pass@host:port)')
    parser.add_argument('--json', action='store_true', help='Output OpenAI-compatible JSON')
    parser.add_argument('--stream', action='store_true', help='Stream response')
    parser.add_argument('--quiet', '-q', action='store_true', help='Suppress logs')
    parser.add_argument('--image', help='Image file path or base64 data:image/...')
    parser.add_argument('--conversation-id', help='Resume existing conversation')
    parser.add_argument('--parent-message-id', help='Parent message for follow-up')

    args = parser.parse_args()

    if args.quiet:
        import warnings
        warnings.filterwarnings('ignore', category=FutureWarning)
        import wrapper.logger
        wrapper.logger.Log.Success = lambda *a, **kw: None
        wrapper.logger.Log.Error = lambda *a, **kw: None
        wrapper.logger.Log.Info = lambda *a, **kw: None

    if args.message:
        text = ' '.join(args.message)
    elif not sys.stdin.isatty():
        text = sys.stdin.read().strip()
    else:
        parser.print_help()
        sys.exit(1)

    image_data = None
    if args.image:
        if args.image.startswith('data:image'):
            image_data = args.image
        else:
            with open(args.image, 'rb') as f:
                import base64
                b64 = base64.b64encode(f.read()).decode()
                image_data = f'data:image/png;base64,{b64}'

    try:
        client = ChatGPT(proxy=args.proxy) if args.proxy else ChatGPT()
        result = client.converse(
            message=text,
            image=image_data,
            conversation_id=args.conversation_id,
            parent_message_id=args.parent_message_id,
        )
    except SystemExit:
        print('error: IP flagged by ChatGPT', file=sys.stderr)
        sys.exit(2)
    except Exception as e:
        print(f'error: {e}', file=sys.stderr)
        sys.exit(1)

    if args.stream:
        print(result['text'], end='' if result['text'].endswith('\n') else '\n')
        return

    if args.json:
        prompt_text = f'user: {text}'
        resp = _build_openai_response(result, prompt_text)
        print(_json.dumps(resp, indent=2, ensure_ascii=False))
        return

    print(result['text'])


if __name__ == '__main__':
    main()
