#!/usr/bin/env python3
import json as _json
import sys
from time import time
from uuid import uuid4

from engine.session import ChatGPT

try:
    import tiktoken
    _enc = tiktoken.get_encoding('o200k_base')
    def _count(s):
        return len(_enc.encode(s)) if s else 0
except ImportError:
    def _count(s):
        return max(1, len(s) // 4)


def _build_openai_response(result, prompt_text):
    model = result['model'] or 'auto'
    content = result['text']
    now = int(time())
    msg_id = f'chatcmpl-{uuid4().hex[:16]}'

    reasoning_text = ''
    text = content
    if '  ' in content:
        end = content.find('  ')
        reasoning_text = content[3:end]
        text = content[end + 3:]

    pt = _count(prompt_text)
    ct = _count(text)
    rt = _count(reasoning_text) if reasoning_text else 0

    choice_msg = {'role': 'assistant', 'content': text}
    if rt:
        choice_msg['reasoning_content'] = reasoning_text

    usage = {'prompt_tokens': pt, 'completion_tokens': ct, 'total_tokens': pt + ct}
    if rt:
        usage['completion_tokens_details'] = {'reasoning_tokens': rt}

    return {
        'id': msg_id,
        'object': 'chat.completion',
        'created': now,
        'model': model,
        'choices': [{'index': 0, 'message': choice_msg, 'finish_reason': 'stop'}],
        'usage': usage,
    }


def main():
    import argparse
    parser = argparse.ArgumentParser(description='anonchat — ChatGPT guest mode CLI')
    parser.add_argument('message', nargs='*', help='Message to send')
    parser.add_argument('--proxy', help='Proxy (http://user:pass@host:port)')
    parser.add_argument('--json', action='store_true', help='Output OpenAI-compatible JSON')
    parser.add_argument('--stream', action='store_true', help='Stream response to stdout')

    args = parser.parse_args()

    if args.message:
        text = ' '.join(args.message)
    elif not sys.stdin.isatty():
        text = sys.stdin.read().strip()
    else:
        parser.print_help()
        sys.exit(1)

    try:
        client = ChatGPT(proxy=args.proxy) if args.proxy else ChatGPT()
        result = client.ask(text)
    except SystemExit:
        print('error: IP flagged by ChatGPT — try a different proxy', file=sys.stderr)
        sys.exit(2)
    except Exception as e:
        print(f'error: {e}', file=sys.stderr)
        sys.exit(1)

    if args.stream:
        print(result['text'], end='' if result['text'].endswith('\n') else '\n')
        return

    if args.json:
        resp = _build_openai_response(result, f'user: {text}')
        print(_json.dumps(resp, indent=2, ensure_ascii=False))
        return

    print(result['text'])


if __name__ == '__main__':
    main()
