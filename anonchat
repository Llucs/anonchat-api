#!/usr/bin/env python3
"""anonchat — use ChatGPT guest mode from the command line.

Usage:
    anonchat "message"
    anonchat --model auto "message"
    anonchat --proxy http://user:pass@host:port "message"
    anonchat --stream "tell me a story"
    anonchat --json "hello"

Pipe-friendly — reads stdin if no argument given.
"""

import json as _json
import sys
import textwrap

from engine.session import ChatGPT


def _fmt_plain(result):
    return result['text']


def _fmt_json(result):
    return _json.dumps(result, indent=2, ensure_ascii=False)


def _fmt_stream(token_iter):
    for token in token_iter:
        print(token, end='', flush=True)
    print()


def chat(messages, stream=False, proxy=None, **_ignored):
    last = next((m['content'] for m in reversed(messages) if m.get('role') == 'user'), None)
    if not last:
        last = messages[-1]['content'] if messages else ''

    client = ChatGPT(proxy=proxy) if proxy else ChatGPT()
    result = client.ask(last)

    model_name = result['model'] or 'auto'

    if stream:
        for chunk in [result['text']]:
            yield chunk
        return

    yield {
        'text': result['text'],
        'model': model_name,
    }


def main():
    import argparse

    parser = argparse.ArgumentParser(description='ChatGPT guest mode CLI')
    parser.add_argument('message', nargs='*', help='Message to send')
    parser.add_argument('--model', default='auto', help='Model (default: auto)')
    parser.add_argument('--proxy', help='Proxy URL (http://user:pass@host:port)')
    parser.add_argument('--stream', action='store_true', help='Stream response')
    parser.add_argument('--json', action='store_true', help='Output JSON')
    parser.add_argument('--temperature', type=float)
    parser.add_argument('--top-p', type=float)
    parser.add_argument('--max-tokens', type=int)
    parser.add_argument('--seed', type=int)

    args = parser.parse_args()

    if args.message:
        text = ' '.join(args.message)
    elif not sys.stdin.isatty():
        text = sys.stdin.read().strip()
    else:
        parser.print_help()
        sys.exit(1)

    messages = [{'role': 'user', 'content': text}]

    try:
        results = list(chat(messages, stream=args.stream, proxy=args.proxy))

        if args.stream:
            for chunk in results:
                print(chunk, end='', flush=True)
            print()
        elif args.json:
            print(_json.dumps(results[0], indent=2, ensure_ascii=False))
        else:
            out = results[0]['text']
            print(textwrap.fill(out, width=80) if '\n' not in out else out)

    except SystemExit:
        print('error: IP flagged by ChatGPT — try a different proxy', file=sys.stderr)
        sys.exit(2)
    except Exception as e:
        print(f'error: {e}', file=sys.stderr)
        sys.exit(1)


if __name__ == '__main__':
    main()
