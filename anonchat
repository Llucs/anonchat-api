#!/usr/bin/env python3
import json as _json
import sys
from time import time
from uuid import uuid4

from engine.session import ChatGPT
from engine.response import build_chat_response, build_stream_chunk, _count

try:
    import tiktoken
    _enc = tiktoken.get_encoding('o200k_base')
    def _count(s):
        return len(_enc.encode(s)) if s else 0
except ImportError:
    def _count(s):
        return max(1, len(s) // 4)


def main():
    import argparse as _argparse
    parser = _argparse.ArgumentParser(description='anonchat — ChatGPT guest mode CLI')
    parser.add_argument('message', nargs='*', help='Message to send')
    parser.add_argument('--proxy', help='Proxy (http://user:pass@host:port)')
    parser.add_argument('--json', action='store_true', help='Output OpenAI-compatible JSON')
    parser.add_argument('--stream', action='store_true', help='Stream response')
    parser.add_argument('--quiet', '-q', action='store_true', help='Suppress logs')
    parser.add_argument('--image', help='Image file path or base64 data:image/...')
    parser.add_argument('--conversation-id', help='Resume existing conversation')
    parser.add_argument('--parent-message-id', help='Parent message for follow-up')
    parser.add_argument('--model', default='auto', help='Model slug (default: auto)')
    parser.add_argument('--list-models', action='store_true', help='List available models and exit')
    parser.add_argument('--extended', action='store_true', help='Include extra metadata in JSON output')

    args = parser.parse_args()

    if args.quiet:
        import warnings
        warnings.filterwarnings('ignore', category=FutureWarning)
        import wrapper.logger
        wrapper.logger.Log.Success = lambda *a, **kw: None
        wrapper.logger.Log.Error = lambda *a, **kw: None
        wrapper.logger.Log.Info = lambda *a, **kw: None

    if args.list_models:
        client = ChatGPT(proxy=args.proxy) if args.proxy else ChatGPT()
        models = client.list_models()
        def _build(m):
            pf = m.get('product_features', {})
            att = pf.get('attachments', {})
            return {
                'id': m['slug'],
                'name': m.get('title', ''),
                'object': 'model',
                'owned_by': 'openai',
                'info': {
                    'name': m.get('title', ''),
                    'description': m.get('description', ''),
                    'max_tokens': m.get('max_tokens', 0),
                    'abilities': {
                        'vision': 1 if att.get('image_mime_types') else 0,
                        'document': 1 if att.get('accepted_mime_types') else 0,
                        'thinking': 1 if m.get('reasoning_type') not in (None, 'none') else 0,
                    },
                    'tools': m.get('enabled_tools', []),
                    'tags': m.get('tags', []),
                },
            }
        print(_json.dumps({'object': 'list', 'data': [_build(m) for m in models]}, indent=2))
        return

    if args.message:
        text = ' '.join(args.message)
    elif not sys.stdin.isatty():
        text = sys.stdin.read().strip()
    else:
        parser.print_help()
        sys.exit(1)

    image_data = None
    if args.image:
        if args.image.startswith('data:image'):
            image_data = args.image
        else:
            with open(args.image, 'rb') as f:
                import base64
                b64 = base64.b64encode(f.read()).decode()
                image_data = f'data:image/png;base64,{b64}'

    if args.stream:
        try:
            client = ChatGPT(proxy=args.proxy) if args.proxy else ChatGPT()
            requested_model = None if args.model == 'auto' else args.model
            now = int(time())
            msg_id = f'chatcmpl-{uuid4().hex[:16]}'
            model = requested_model or 'auto'
            sys.stdout.write(f'data: {_json.dumps(build_stream_chunk(msg_id, now, model, {"role": "assistant", "content": ""}))}\n\n')
            sys.stdout.flush()
            for event in client.converse_stream(
                message=text,
                image=image_data,
                conversation_id=args.conversation_id,
                parent_message_id=args.parent_message_id,
                model=requested_model,
            ):
                if event['type'] == 'chunk':
                    chunk_data = build_stream_chunk(msg_id, now, model, {'content': event['text']})
                    sys.stdout.write(f'data: {_json.dumps(chunk_data)}\n\n')
                    sys.stdout.flush()
                elif event['type'] == 'done':
                    model = event.get('model') or model
                elif event['type'] == 'error':
                    chunk_data = build_stream_chunk(msg_id, now, model, {}, 'error')
                    sys.stdout.write(f'data: {_json.dumps(chunk_data)}\n\n')
                    sys.stdout.flush()
            chunk_data = build_stream_chunk(msg_id, now, model, {}, 'stop')
            sys.stdout.write(f'data: {_json.dumps(chunk_data)}\n\n')
            sys.stdout.write('data: [DONE]\n\n')
            sys.stdout.flush()
        except Exception as e:
            print(f'error: {e}', file=sys.stderr)
            sys.exit(1)
        return

    try:
        client = ChatGPT(proxy=args.proxy) if args.proxy else ChatGPT()
        requested_model = None if args.model == 'auto' else args.model
        result = client.converse(
            message=text,
            image=image_data,
            conversation_id=args.conversation_id,
            parent_message_id=args.parent_message_id,
            model=requested_model,
        )
    except SystemExit:
        print('error: IP flagged by ChatGPT', file=sys.stderr)
        sys.exit(2)
    except Exception as e:
        print(f'error: {e}', file=sys.stderr)
        sys.exit(1)

    if args.json:
        prompt_text = f'user: {text}'
        resp = build_chat_response(result, prompt_text, result.get('model', 'auto'), extended=args.extended)
        print(_json.dumps(resp, indent=2, ensure_ascii=False))
        return

    print(result['text'])


if __name__ == '__main__':
    main()
